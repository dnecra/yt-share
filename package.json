{
  "name": "ytm-share",
  "version": "1.0.0",
  "description": "YouTube Music Remote Server",
  "main": "bundle.js",
  "bin": "bundle.js",
    "scripts": {
    "dev": "nodemon server.js",
    "build:bundle": "esbuild server.js --bundle --platform=node --outfile=bundle.js --external:kuromoji",
    "build": "npm run build:bundle && pkg . --targets node18-win-x64 --output dist/ytm-share-server.exe",
    "build:gui": "npm run build:bundle && pkg . --targets node18-win-x64 --output dist/ytm-share-server-tray.exe --no-console"
  },

  "dependencies": {
    "axios": "^1.6.2",
    "es-hangul": "^2.3.8",
    "hono": "^4.0.0",
    "kuromoji": "^0.1.2",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "pinyin-pro": "^3.28.0",
    "tinyld": "^1.3.4",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "nodemon": "^3.0.2",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "node_modules/kuromoji/dict/**/*"
    ]
  }
}
